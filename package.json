{
  "name": "monitoringapp",
  "version": "1.0.0",
  "description": "Monitoring app for microservices in kubernetes",
  "keywords": [
    "node",
    "redis",
    "kubernetes",
    "microservices",
    "prometheus"
  ],
  "homepage": "https://github.com/vishalmindfire/monitoringApp#readme",
  "bugs": {
    "url": "https://github.com/vishalmindfire/monitoringApp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vishalmindfire/monitoringApp.git"
  },
  "license": "GPL-3.0",
  "author": "Vishal Minz",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx --watch --env-file .env.development src/index.ts",
    "dev:staging": "tsx --watch --env-file .env.staging src/index.ts",
    "dev:prod": "tsx --watch --env-file .env.production src/index.ts",
    "dev:worker": "tsx --watch --env-file .env.development src/worker.ts",
    "dev:aggregator": "tsx --watch --env-file .env.development src/aggregator.ts",
    "start": "node --env-file .env.production dist/src/index.js",
    "start:worker": "node --env-file .env.production dist/src/worker.js",
    "start:aggregator": "node --env-file .env.production dist/src/aggregator.js",
    "build": "tsc -p tsconfig.prod.json",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "morgan": "^1.11.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "imports": {
    "#*": {
      "development": "./src/*",
      "types": "./src/*",
      "default": "./dist/src/*"
    }
  }
}
